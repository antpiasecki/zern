include "std/io.zr"
include "std/containers.zr"

func multiply[n: Array, x: i64] : void
    carry := 0
    for i in 0..n->size
        prod : i64 = n->nth(i) * x + carry
        n->set(i, prod % 10)
        carry = prod / 10
    while carry > 0
        n->push(carry % 10)
        carry = carry / 10

func main[] : i64
    n := [1]

    for i in 2..101
        multiply(n, i)

    sum := 0
    for i in 0..n->size
        sum += n->nth(i)
    
    io.println_i64(sum)
