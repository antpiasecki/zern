func main[] : i64
    answer := math.abs(os.urandom_i64()) % 100

    while true
        io.println("Guess a number: ")
        guess := str.parse_i64(io.read_line())

        if guess == answer
            io.println("You win!")
            break
        else if guess < answer
            io.println("Too low!")
        else
            io.println("Too high!")
