include "std/io.zr"
include "std/os.zr"

func main[] : i64
    arr := []
    for i in 0..10
        arr->push(os.urandom_i64()->abs() % 1000)

    for i in 0..arr->size
        io.println_i64(arr->nth(i))
    io.println("------------")

    arr->quicksort()

    for i in 0..arr->size
        io.println_i64(arr->nth(i))

    arr->free()
